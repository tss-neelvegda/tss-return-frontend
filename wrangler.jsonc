{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tss-return-frontend",
  "compatibility_date": "2026-06-11",
  "main": ".output/server/index.mjs",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".output/public"
  },
  "observability": {
    "enabled": true
  }
}
